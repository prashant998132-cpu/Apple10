{
  "name": "JARVIS AI Assistant",
  "short_name": "JARVIS",
  "description": "Your Personal AI — Groq + Gemini + Phone Control",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "background_color": "#070810",
  "theme_color": "#070810",
  "orientation": "portrait-primary",
  "lang": "hi",
  "categories": ["productivity", "utilities"],
  "prefer_related_applications": false,
  "icons": [
    { "src": "/icons/icon-72.png",  "sizes": "72x72",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-96.png",  "sizes": "96x96",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-128.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-152.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "/icons/icon-384.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "shortcuts": [
    { "name": "New Chat",   "url": "/?new=1",       "description": "Start a new conversation", "icons": [{"src": "/icons/icon-96.png", "sizes": "96x96"}] },
    { "name": "Voice Mode", "url": "/?voice=1",     "description": "Start voice assistant",    "icons": [{"src": "/icons/icon-96.png", "sizes": "96x96"}] },
    { "name": "Weather",    "url": "/?cmd=weather", "description": "Check weather",            "icons": [{"src": "/icons/icon-96.png", "sizes": "96x96"}] },
    { "name": "Image Gen",  "url": "/?cmd=image",   "description": "Generate an image",        "icons": [{"src": "/icons/icon-96.png", "sizes": "96x96"}] }
  ],
  "screenshots": [
    { "src": "/icons/screenshot-1.png", "sizes": "390x844", "type": "image/png", "form_factor": "narrow", "label": "JARVIS Chat Interface" }
  ],
  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "shared_title",
      "text": "shared_text",
      "url": "shared_url",
      "files": [{ "name": "shared_file", "accept": ["image/*", "application/pdf", "text/*", "audio/*"] }]
    }
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".gif", ".webp"],
        "application/pdf": [".pdf"],
        "text/*": [".txt", ".md"],
        "audio/*": [".mp3", ".m4a", ".wav"]
      }
    }
  ],
  "protocol_handlers": [
    { "protocol": "web+jarvis", "url": "/?cmd=%s" }
  ],
  "launch_handler": { "client_mode": "focus-existing" },
  "handle_links": "preferred",
  "related_applications": []
}

# JARVIS v39 — Complete Environment Variables
# Vercel Dashboard > Settings > Environment Variables mein add karo

# ── AI PROVIDERS ──────────────────────────────────────
GROQ_API_KEY=                    # groq.com — FREE 14,400/day
GEMINI_API_KEY=                  # aistudio.google.com — FREE 1,500/day
ANTHROPIC_API_KEY=               # console.anthropic.com — Claude Haiku (paid but cheap)
MISTRAL_API_KEY=                 # console.mistral.ai — FREE tier
OPENROUTER_API_KEY=              # openrouter.ai — FREE models
TOGETHER_API_KEY=                # api.together.xyz — FREE $25 credits
DEEPSEEK_API_KEY=                # platform.deepseek.com — FREE credits
CEREBRAS_API_KEY=                # inference.cerebras.ai — FREE tier

# ── TOOLS & DATA ──────────────────────────────────────
NEWS_API_KEY=                    # newsapi.org — FREE 100/day
NASA_API_KEY=DEMO_KEY            # api.nasa.gov — FREE (DEMO_KEY works!)
TMDB_API_KEY=                    # themoviedb.org — FREE 1,000/day
CRICAPI_KEY=                     # cricapi.com — cricket scores
PEXELS_API_KEY=                  # pexels.com/api — FREE 200/hr
YOUTUBE_API_KEY=                 # console.cloud.google.com — FREE 10k/day
ALPHA_VANTAGE_KEY=               # alphavantage.co — FREE 25/day

# ── MESSAGING ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=              # BotFather — FREE
TELEGRAM_CHAT_ID=                # Your Telegram ID

# ── TTS ───────────────────────────────────────────────
ELEVENLABS_API_KEY=              # elevenlabs.io — FREE 10k chars/month

# ── STORAGE (Optional) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=        # supabase.com — FREE 500MB
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # supabase.com
NEXT_PUBLIC_UPSTASH_VECTOR_URL=  # upstash.com — FREE 10k vectors
NEXT_PUBLIC_UPSTASH_VECTOR_TOKEN=

# ── SEARCH ────────────────────────────────────────────
BRAVE_API_KEY=                   # api.search.brave.com — FREE 2000/month
SERPER_API_KEY=                  # serper.dev — FREE 2500/month
TAVILY_API_KEY=                  # tavily.com — FREE 1000/month

# ─────────────────────────────────────────────────────
# MINIMUM: Sirf GROQ_API_KEY ya GEMINI_API_KEY chahiye!
# Baaki sab optional — Pollinations fallback always works
# ─────────────────────────────────────────────────────

# ── ADDITIONAL PROVIDERS ──────────────────────────────
EXA_API_KEY=                     # exa.ai — FREE 1000/month (semantic search)
HUGGINGFACE_API_KEY=             # huggingface.co — FREE tier (image gen, TTS)
FISH_API_KEY=                    # fish.audio — #1 TTS quality (paid)

# ── REQUIRED FOR SECURITY ─────────────────────────────
# CRON_SECRET must be set! Generate: openssl rand -hex 16
CRON_SECRET=change_me_to_random_string
